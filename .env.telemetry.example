# Telemetry Configuration
# This log file is versioned in the .telemetry/ directory and is a valid JSON array
OTEL_LOG_PATH=.telemetry/gemini-gitops.json

# OTLP Collector (Optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service Identification
OTEL_SERVICE_NAME=homeServerPi-agent
GEN_AI_SYSTEM=gemini-cli
GEN_AI_MODEL=gemini-1.5-pro
