# Infrastructure
MOUNT_USB_DRIVE=/media/usb-media
DEPLOY_PATH=/home/cristian/music-stack
PUID=1000
PGID=1000
SSD_UUID=      # e.g., 1234-5678-ABCD-EFGH
SSD_FORMAT=ext4
SSH_PUBLIC_KEY_PATH=~/.ssh/id_rsa.pub

# Service Configs (Navidrome, Yubal, Home Assistant, etc.)
NAVIDROME_PORT=4533
YUBAL_PORT=4000
YUBAL_SCHEDULER_CRON=0 0 * * *
YUBAL_DOWNLOAD_UGC=false
YUBAL_TZ=UTC

# Home Assistant & ESPHome
HASS_CONFIG_DIR=/media/usb-media/config/homeassistant
ESPHOME_CONFIG_DIR=/media/usb-media/config/esphome
